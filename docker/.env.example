# Copy to .env and fill before `docker compose up`.
# .env is gitignored.

# ----- Postgres -----
POSTGRES_USER=prime
POSTGRES_PASSWORD=replace-me-with-a-strong-password
POSTGRES_DB=primes

# ----- App -----
LOG_LEVEL=INFO
PRIME_MAX_RANGE=10000000

# ----- WireGuard -----
# Public hostname or IP that peers will dial. `auto` = container detects.
WG_SERVER_URL=auto
# Number of peer configs to generate.
WG_PEERS=2
