        <mxCell id="iam" value="IAM Identity Center&#xa;(human access)&#xa;&#xa;grp-developers (RO)&#xa;grp-devops&#xa;grp-admins" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;strokeWidth=1.5;fontSize=11;fontColor=#312e81;align=center;" vertex="1" parent="1">
