        <!-- ECS-b -> CloudWatch (logs out) -->
        <mxCell id="e_ecs_cw" value="structured logs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#0ea5e9;dashed=1;fontSize=10;fontColor=#0c4a6e;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ecsb" target="cw">
