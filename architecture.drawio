        <!-- =========================================================== -->
        <!--  EDGES (orthogonal, linear, no crossings)                     -->
        <!-- =========================================================== -->

        <!-- Operator -> Client VPN (right side of operator -> left side of clientvpn) -->
        <mxCell id="e_op_vpn" value="UDP/443 mTLS" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#374151;fontSize=10;fontColor=#374151;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="operator" target="clientvpn">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client VPN -> ALB (bottom of clientvpn -> top of ALB) - straight down -->
        <mxCell id="e_vpn_alb" value="authorized to VPC CIDR" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#374151;fontSize=10;fontColor=#374151;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="clientvpn" target="alb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ALB -> ECS-a (vertical drop into AZ-a column) -->
        <mxCell id="e_alb_ecsa" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#374151;" edge="1" parent="1" source="alb" target="ecsa">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ALB -> ECS-b (vertical drop into AZ-b column) -->
        <mxCell id="e_alb_ecsb" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#374151;" edge="1" parent="1" source="alb" target="ecsb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ECS-a -> RDS-a (5432, vertical) -->
        <mxCell id="e_ecsa_rdsa" value="5432" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#374151;fontSize=10;fontColor=#374151;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ecsa" target="rdsa">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ECS-b -> RDS-b -->
        <mxCell id="e_ecsb_rdsb" value="5432 (failover)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#374151;dashed=1;fontSize=10;fontColor=#374151;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ecsb" target="rdsb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- RDS-a -> RDS-b (sync replication, horizontal between siblings, no crossings) -->
        <mxCell id="e_rds_repl" value="sync replication" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#a855f7;dashed=1;fontSize=10;fontColor=#581c87;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="rdsa" target="rdsb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ECR -> ECS-b (image pull, enters from right side of ECS-b) -->
        <mxCell id="e_ecr_ecs" value="image pull" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.3;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#0ea5e9;dashed=1;fontSize=10;fontColor=#0c4a6e;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ecr" target="ecsb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Secrets -> ECS-b (DATABASE_URL injection) -->
        <mxCell id="e_sec_ecs" value="DATABASE_URL" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.7;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#0ea5e9;dashed=1;fontSize=10;fontColor=#0c4a6e;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="secrets" target="ecsb">
          <mxGeometry relative="1" as="geometry" />
