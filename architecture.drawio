        <!-- =========================================================== -->
        <!--  External actors (left column)                                -->
        <!-- =========================================================== -->
        <mxCell id="operator" value="Operator / Developer&#xa;&#xa;AWS Client VPN client&#xa;(mTLS .ovpn profile)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;strokeWidth=1.5;fontSize=11;fontColor=#1f2937;align=center;" vertex="1" parent="1">
